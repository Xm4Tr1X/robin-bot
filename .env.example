# Loaded by Node --env-file=.env (package.json start/dev). Copy to .env and fill in values.
# Secrets in robin.json reference these by name (e.g. SLACK_BOT_TOKEN); never put secrets in robin.json.

# Slack credentials
# Create a Slack App at https://api.slack.com/apps
# Enable Socket Mode + generate App-Level Token (connections:write scope)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Owner Slack user ID (used for DM check-ins and snapshot restoration prompts)
# Find it: Slack > Profile > ... > Copy member ID
SLACK_OWNER_USER_ID=U...

# Optional: channel to send proactive check-ins to (defaults to DM if not set)
# SLACK_CHECKIN_CHANNEL=C...

# Max Claude Code turns per Slack message (default: 10)
# ROBIN_MAX_TURNS=10

# Snapshot directory (relative to project root)
SNAPSHOT_DIR=./snapshots
